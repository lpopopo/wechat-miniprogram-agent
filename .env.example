# ============================================================
# LLM Configuration（必填）
# ============================================================
# 支持任何 OpenAI 兼容接口
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ============================================================
# WeChat Configuration
# ============================================================
# macOS: 填写 WeChat app bundle 名称（默认 "WeChat"）或完整路径
#   WECHAT_EXE_PATH=WeChat
#   WECHAT_EXE_PATH=/Applications/WeChat.app
# Windows: 填写 exe 完整路径
#   WECHAT_EXE_PATH=C:\Program Files (x86)\Tencent\WeChat\WeChat.exe
WECHAT_WINDOW_TITLE=微信
# WECHAT_EXE_PATH=WeChat

# ============================================================
# Agent Configuration（可选）
# ============================================================
MAX_STEPS=30
SCREENSHOT_INTERVAL=1.0
ACTION_DELAY=0.5

# ============================================================
# Screenshot Configuration（可选）
# ============================================================
SCREENSHOT_DIR=screenshots
SAVE_SCREENSHOTS=true
